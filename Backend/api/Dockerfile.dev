# Development-only image.
#
# We use the Debian-slim base (not Alpine) because Cloudflare's `workerd`
# binary is linked against glibc — running it on musl/Alpine yields
# "Failed to validate workerd binary" + ENOENT at spawn time.
FROM node:22-bookworm-slim

RUN apt-get update \
 && apt-get install -y --no-install-recommends git gosu ca-certificates \
 && rm -rf /var/lib/apt/lists/* \
 && corepack enable

WORKDIR /app

COPY docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
EXPOSE 8787
